{
  "expo": {
    "name": "MAK - Personalized Styling & Makeup",
    "slug": "mak-makeup-buddy",
    "version": "1.0.10",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mak",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mak.makeupbuddy",
      "infoPlist": {
        "NSCameraUsageDescription": "Take selfies for personalized skin analysis",
        "NSPhotoLibraryUsageDescription": "Select photos for skin analysis"
      }
    },
    "android": {
      "package": "com.mak.makeupbuddy",
      "versionCode": 110,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFF8F5"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow MAK to access your camera for skin analysis"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow MAK to access your photos for skin analysis"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "b6909e6a-7f66-4e7b-ba27-e1078aa91b0a"
      }
    },
    "owner": "McmExpo"
  }
}
